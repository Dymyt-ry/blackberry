# ── BBMM backend ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. Do NOT use special chars (# $ !) in tokens —
# Docker/Coolify may truncate the value there. Alphanumeric only.

# HTTP
PORT=3000

# Token the BlackBerry app sends as the `x-api-token` header on every request.
AUTH_TOKEN=changeme_alnum_only

# Comma-separated list of networks to enable. MVP: whatsapp,sms
# Full set once built: whatsapp,sms,instagram  (tiktok is a stub, never enable)
ENABLED_NETWORKS=whatsapp,sms

# Where the crash-recovery snapshot is written (JSON). Keep on a writable volume.
SNAPSHOT_PATH=./data/snapshot.json

# Cache bounds — stop a spoofed/chatty network from OOMing the aggregator.
MAX_MESSAGES_PER_CONVERSATION=300
MAX_CONVERSATIONS=1000
MAX_SEEN_IDS=20000
MAX_TEXT_LENGTH=8192

# ── whatsapp gateway (Evolution API v2 — Baileys) ────────────────────────────
# Use a DEDICATED/secondary WhatsApp number you can afford to lose (ban risk).
EVO_API_URL=http://evolution:8081
EVO_INSTANCE_NAME=bbmm
EVO_API_KEY=your-evolution-api-key
# STRONGLY RECOMMENDED: shared secret for the inbound webhook. Register the
# webhook URL as https://backend/webhook/whatsapp?secret=THIS_VALUE (Evolution
# doesn't sign webhooks). Without it, /webhook/whatsapp is open to spoofing.
WA_WEBHOOK_SECRET=

# ── sms gateway (self-hosted Android SMS gateway on a spare SIM phone) ────────
# Supported adapters: "smsgate" (sms-gate.app) | "httpsms" | "textbee".
SMS_PROVIDER=smsgate
SMS_API_URL=http://sms-phone.local:8080
SMS_API_USER=sms
SMS_API_PASSWORD=changeme
# Shared secret the SMS gateway includes on its inbound webhook (optional).
SMS_WEBHOOK_SECRET=

# ── instagram gateway (mautrix-meta on a contained homeserver — built LAST) ───
# Left blank until the Instagram box exists. Use a burner IG account.
IG_HOMESERVER_URL=
IG_ACCESS_TOKEN=
IG_USER_ID=
